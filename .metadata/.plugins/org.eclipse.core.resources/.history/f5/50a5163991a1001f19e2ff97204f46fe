import java.util.Scanner;
public class Q4 {

	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int var, lastdig, middledig, firstdig, temp, sum;
		var = sc.nextInt();
		lastdig = var % 10;
		temp = var / 10;
		middledig = temp % 10;
		firstdig = temp / 10;
		sum = firstdig + middledig + lastdig;
		System.out.println(sum);
		
		

	}

}
